{
  "expo": {
    "name": "TimelyOne",
    "slug": "salonix-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-native.png",
      "resizeMode": "contain",
      "backgroundColor": "#3b82f6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.timelyone.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3b82f6"
      },
      "package": "com.timelyone.app",
      "permissions": [
        "NOTIFICATIONS",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-notifications",
      "expo-asset",
      "expo-font",
      "expo-secure-store"
    ],
    "extra": {
      "API_BASE_URL": "http://192.168.0.221:8000/api/",
      "RESET_URL": "http://192.168.0.221:5173/reset-password",
      "eas": {
        "projectId": "6642ca0c-7940-4fd3-b2a9-1af204db242b"
      }
    }
  }
}
