{
  "cli": {
    "version": ">= 16.15.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "API_BASE_URL": "http://0.0.0.0:8000/api/",
        "RESET_URL": "http://0.0.0.0:8000/reset-password"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "API_BASE_URL": "https://timelyonestaging.pythonanywhere.com/api/",
        "RESET_URL": "https://timelyonestaging.pythonanywhere.com/reset-password"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "API_BASE_URL": "https://salonix-backend-production.up.railway.app/api/",
        "RESET_URL": "https://salonix-backend-production.up.railway.app/reset-password"
      }
    }
  },
  "submit": {
    "production": { }
  }
}
